# Docker
.dockerignore

# Python
__pycache__/
*.pyc
*.pyo
*.egg-info/
build/
# NOTE: dist/ is intentionally NOT ignored — CI builds the wheel
# on the runner (so hatch-vcs can read the git tag) and the Docker
# image installs that pre-built wheel from dist/.

# Environments
.env
.venv
venv/

# IDE
.vscode/
.idea/

# Git
.git/
.gitignore

# CI
.github/

# Output
output/

# Cache
.pytest_cache/
.mypy_cache/
.ruff_cache/
